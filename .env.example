# Copy to .env.local and fill in. Never commit real secrets.

# --- Database (Postgres / Supabase) ----------------------------------------
# App runtime: use the *transaction* pooler (port 6543) — required for serverless.
#   postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
# Migrations / drizzle-kit: use the *session* pooler (5432) or the direct URL.
DIRECT_URL=

# --- Auth.js (NextAuth v5) -------------------------------------------------
# Generate with:  openssl rand -base64 33
AUTH_SECRET=
# Only needed if not running on localhost / behind a proxy:
# AUTH_URL=http://localhost:3000

# --- Holded integration ----------------------------------------------------
# Holded > Settings > Developers > API key
HOLDED_API_KEY=
# Base URL — leave as-is unless Holded changes it
HOLDED_API_BASE=https://api.holded.com/api
# A secret you choose; configure the same value on the Holded webhook so we can
# verify incoming calls (sent as the `key` query param or `X-Webhook-Secret` header).
HOLDED_WEBHOOK_SECRET=

# --- Habitat-one website push ---------------------------------------------
# Fine-grained PAT met Contents: Read+Write op alleen `nickhouter-ctrl/Habitat-one`.
# Maak hier aan: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN_HABITAT_ONE=
# Default is voldoende; overschrijf bij naamwijziging
WEBSITE_REPO=nickhouter-ctrl/Habitat-one
WEBSITE_BRANCH=main

# --- Supabase Storage ------------------------------------------------------
# Bucket-namen — defaults zijn meestal prima
# SUPABASE_STORAGE_BUCKET=property-images
# SUPABASE_PRODUCT_BUCKET=product-images
# SUPABASE_PO_BUCKET=purchase-order-files

# --- Gmail (IMAP-poll voor de mail-inbox + SMTP voor uitgaande mail) --------
# Gmail-adres + een Gmail app-wachtwoord (Account > Beveiliging > App-wachtwoorden,
# vereist 2-staps-verificatie). Het CRM pollt dit postvak via IMAP.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optioneel tweede postvak (bv. purchase@) — een apart Gmail-account met een
# eigen app-wachtwoord. Leeg laten als er maar één postvak is.
GMAIL_PURCHASE_USER=
GMAIL_PURCHASE_APP_PASSWORD=

# Uitgaande klant-mails (offertes, bevestigingen) gaan standaard via Gmail
# (verstuurd vanaf GMAIL_USER). Resend is een optionele terugval:
# RESEND_API_KEY=
# EMAIL_FROM=hi@habitat-one.com

# --- Meldingen -------------------------------------------------------------
# Adres dat een melding krijgt als een klant een offerte accepteert of afwijst.
# Leeg laten = valt terug op het bedrijfsadres (COMPANY_EMAIL / hi@habitat-one.com).
NOTIFY_EMAIL=
# Elke uitgaande klantmail (offerte/factuur/herinnering/levering) krijgt een kopie
# (CC) naar dit adres zodat je altijd meeleest. Leeg = NOTIFY_EMAIL, anders GMAIL_USER.
EMAIL_CC=

# --- Bedrijfsgegevens op PDF/mail (optioneel — defaults in lib/company.ts) --
# Adres in twee regels op de PDF: straat, en daaronder postcode + plaats + land.
# COMPANY_ADDRESS_STREET=Camí de la Fontana 3, Locales 2, 3 en 5
# COMPANY_ADDRESS_REGION=03730 Jávea (Alicante), España
